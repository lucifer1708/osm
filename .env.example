# ─── Object Storage ───────────────────────────────────────
# Leave ENDPOINT blank for standard AWS S3
ENDPOINT=
ACCESS_KEY=your-access-key
SECRET_KEY=your-secret-key
REGION=us-east-1

# ─── Optional overrides ────────────────────────────────────
# DB_PATH=./data/osm.db   (default)
# PORT=8080               (default)
# PUBLIC_FILES_HOST=static.example.com   Public URL prefix for file links (e.g. CDN/proxy domain)
#   When set, public file URLs become: https://static.example.com/files/<bucket>/<key>
#   Route /files/{path} on this host to the OSM instance (no auth required for public objects)
# FILES_PORT=9090                        Start a dedicated public-files server on this port (no auth)
#   If set, serves public objects at http://host:FILES_PORT/files/<bucket>/<key>

# ─── Provider examples ────────────────────────────────────
# AWS S3        ENDPOINT=  REGION=us-east-1
# MinIO         ENDPOINT=http://localhost:9000  REGION=us-east-1
# Cloudflare R2 ENDPOINT=https://<account>.r2.cloudflarestorage.com  REGION=auto
# Backblaze B2  ENDPOINT=https://s3.<region>.backblazeb2.com  REGION=us-west-002
# Wasabi        ENDPOINT=https://s3.wasabisys.com  REGION=us-east-1
# Hetzner       ENDPOINT=<location>.your-objectstorage.com  REGION=<location>
